# ─────────────────────────────────────────────
# T-Care API Keys — DO NOT COMMIT THIS FILE
# ─────────────────────────────────────────────

# Google Maps JavaScript API key
# Enable: Maps JavaScript API, Directions API, Places API
# https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# AWS credentials for Amazon Bedrock (Claude / Titan)
# IAM permissions needed: bedrock:InvokeModel
# https://console.aws.amazon.com/iam/
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID_HERE
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY_HERE
AWS_SESSION_TOKEN=YOUR_AWS_SESSION_TOKEN_HERE
AWS_REGION=us-east-1

# Amazon Bedrock model ID to use for NLP
BEDROCK_MODEL_ID=amazon.nova-micro-v1:0

# (Optional) Amazon Kendra index ID — if you have a Kendra index
# set up with UofT documents for richer intent matching
# Leave blank to skip Kendra and use Bedrock only
KENDRA_INDEX_ID=

# Port for the local backend server
PORT=3001
